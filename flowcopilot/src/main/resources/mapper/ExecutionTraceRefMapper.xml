<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="aliang.flowcopilot.mapper.ExecutionTraceRefMapper">

    <resultMap id="BaseResultMap" type="aliang.flowcopilot.model.entity.ExecutionTraceRef">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="workflowInstanceId" column="workflow_instance_id" jdbcType="VARCHAR"/>
        <result property="traceId" column="trace_id" jdbcType="VARCHAR"/>
        <result property="graphTemplate" column="graph_template" jdbcType="VARCHAR"/>
        <result property="nodeKey" column="node_key" jdbcType="VARCHAR"/>
        <result property="eventType" column="event_type" jdbcType="VARCHAR"/>
        <result property="status" column="status" jdbcType="VARCHAR"/>
        <result property="inputSnapshot" column="input_snapshot" jdbcType="VARCHAR"/>
        <result property="outputSnapshot" column="output_snapshot" jdbcType="VARCHAR"/>
        <result property="errorMessage" column="error_message" jdbcType="VARCHAR"/>
        <result property="durationMs" column="duration_ms" jdbcType="BIGINT"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="aliang.flowcopilot.model.entity.ExecutionTraceRef"
            keyColumn="id" keyProperty="id" useGeneratedKeys="true">
        INSERT INTO execution_trace_ref
        (
            workflow_instance_id,
            trace_id,
            graph_template,
            node_key,
            event_type,
            status,
            input_snapshot,
            output_snapshot,
            error_message,
            duration_ms,
            created_at
        )
        VALUES
        (
            CAST(#{workflowInstanceId} AS uuid),
            #{traceId},
            #{graphTemplate},
            #{nodeKey},
            #{eventType},
            #{status},
            CAST(#{inputSnapshot} AS jsonb),
            CAST(#{outputSnapshot} AS jsonb),
            #{errorMessage},
            #{durationMs},
            #{createdAt}
        )
    </insert>

    <select id="selectByWorkflowInstanceId" resultMap="BaseResultMap">
        SELECT id,
               workflow_instance_id,
               trace_id,
               graph_template,
               node_key,
               event_type,
               status,
               input_snapshot::text AS input_snapshot,
               output_snapshot::text AS output_snapshot,
               error_message,
               duration_ms,
               created_at
        FROM execution_trace_ref
        WHERE workflow_instance_id = CAST(#{workflowInstanceId} AS uuid)
        ORDER BY created_at ASC
    </select>
</mapper>
